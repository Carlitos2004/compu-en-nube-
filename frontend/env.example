# ─────────────────────────────────────────────────────
#  VARIABLES DE ENTORNO — FRONTEND (Vite)
#  Copia este archivo como .env y llena los valores
#  IMPORTANTE: Las variables deben empezar con VITE_
# ─────────────────────────────────────────────────────

# URL del backend (local durante desarrollo)
VITE_API_URL=http://localhost:5000

# Amazon Cognito (lo llenas cuando configures Cognito en AWS)
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_COGNITO_DOMAIN=https://grupo4.auth.us-east-1.amazoncognito.com
VITE_COGNITO_REDIRECT_URI=http://localhost:3000/dashboard
