# Puerto del servidor
PORT=5000

# Feature Flags - Controla qué módulos están habilitados
FEATURE_AUTH_ENABLED=false
FEATURE_USERS_ENABLED=false
FEATURE_TASKS_ENABLED=false
FEATURE_CATEGORIES_ENABLED=false
FEATURE_TEAMS_ENABLED=false
FEATURE_NOTIFICATIONS_ENABLED=false
FEATURE_REPORTS_ENABLED=false
FEATURE_INTEGRATIONS_ENABLED=false

# Nota: Los módulos deshabilitados no exponen sus endpoints
# Para desarrollo local, establecer el feature flag correspondiente en true
